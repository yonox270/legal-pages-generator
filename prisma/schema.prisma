generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id          String    @id
  shop        String
  state       String?
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
  createdAt   DateTime  @default(now())
}

model Store {
  id        String   @id @default(cuid())
  shop      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  pages     Page[]
}

model Page {
  id         String   @id @default(cuid())
  shop       String
  type       String
  shopifyId  String?
  shopifyUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [shop], references: [shop])
}